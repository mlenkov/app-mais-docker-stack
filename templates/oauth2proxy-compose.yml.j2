name: mais
services:
  oauth2proxy:
    image: quay.io/oauth2-proxy/oauth2-proxy:v7.5.0
    container_name: {{ container_oauth2proxy }}
    restart: unless-stopped
    expose:
      - "4180"
    networks:
      - {{ net_caddy }}
      - {{ net_bifrost }}
    env_file:
      - {{ oauth2proxy_env_path }}
    volumes:
      - ./emails.txt:/etc/oauth2-proxy/emails.txt:ro
    command:
      - --provider=google
      - --login-url=https://oauth.yandex.ru/authorize
      - --redeem-url=https://oauth.yandex.ru/token
      - --validate-url=https://login.yandex.ru/info
      - --http-address=0.0.0.0:4180
      - --upstream=http://{{ container_bifrost }}:8080
      - --redirect-url=https://{{ domain_app }}/oauth2/callback
      - --email-domain=*
      - --authenticated-emails-file=/etc/oauth2-proxy/emails.txt
      - --cookie-secure=true
      - --cookie-httponly=true
      - --cookie-samesite=lax
      - --skip-provider-button=true
    labels:
      project: "mais"
      service: "oauth2proxy"
      environment: "production"
    deploy:
      resources:
        limits:
          cpus: '0.2'
          memory: 64M
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:4180/ping"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

networks:
  {{ net_caddy }}:
    external: true
    name: {{ net_caddy }}
  {{ net_bifrost }}:
    external: true
    name: {{ net_bifrost }}
